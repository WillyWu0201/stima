    "「%@」已經在客戶簿內。請改名或直接到列表編輯既有資料。": {
      "localizations": {
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」sudah ada di buku klien. Ubah nama atau edit langsung di daftar."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」đã có trong danh bạ khách hàng. Hãy đổi tên hoặc sửa trực tiếp trong danh sách."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\" is already in your contacts. Rename it, or go to the list to edit the existing entry."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」已经在客户簿内。请改名或直接到列表编辑既有资料。"
          }
        }
      }
    },
