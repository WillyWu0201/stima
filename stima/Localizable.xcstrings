    "例：簽約付 30%，完工驗收付 60%，保固期滿付 10%": {
      "localizations": {
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "VD: Ký hợp đồng trả 30%, nghiệm thu trả 60%, hết bảo hành trả 10%"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Cth: Tanda tangan bayar 30%, serah terima 60%, akhir garansi 10%"
