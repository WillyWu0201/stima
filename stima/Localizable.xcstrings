    "免費版每月最多 %lld 張報價單，下個月會自動重置。升級 PRO 解鎖無限張。": {
      "localizations": {
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Versi gratis maksimal %lld penawaran per bulan, otomatis reset bulan depan. Naik ke PRO untuk tanpa batas."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bản miễn phí tối đa %lld báo giá mỗi tháng, sẽ tự đặt lại tháng sau. Nâng cấp PRO để mở khóa không giới hạn."
          }
        },
        "en": {
          "stringUnit": {
