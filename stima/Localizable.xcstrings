    "例：張先生介紹、喜歡北歐風、付款乾脆⋯": {
      "localizations": {
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "VD: Anh Trương giới thiệu, thích phong cách Bắc Âu, thanh toán dứt khoát⋯"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Cth: Referensi Pak Zhang, suka gaya Nordik, bayar lancar⋯"
          }
        }
      }
    },
    "例：拆冷氣、磨地板、外牆貼磚": {
      "localizations": {
        "vi": {
          "stringUnit": {
            "state": "translated",
